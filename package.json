{
  "name": "filepond-plugin-zipper",
  "version": "3.0.0",
  "description": "Zip Filepond Directory Uploads",
  "source": "src/zipper.ts",
  "main": "dist/zipper.js",
  "module": "dist/zipper.esm.js",
  "unpkg": "dist/zipper.min.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "microbundle --name FilepondZipper --globals jszip=JSZip",
    "dev": "microbundle watch --name FilepondZipper --globals jszip=JSZip",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzsk/filepond-plugin-zipper.git"
  },
  "keywords": [
    "filepond",
    "zip directory",
    "upload zipped directory",
    "filepond zip directory"
  ],
  "author": {
    "name": "Kazi Ahmed",
    "email": "mailtokmahmed@gmail.com",
    "url": "https://github.com/tzsk"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tzsk/filepond-plugin-zipper/issues"
  },
  "homepage": "https://github.com/tzsk/filepond-plugin-zipper#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^4.0.18",
    "filepond": "^4.32.12",
    "jsdom": "^28.1.0",
    "microbundle": "^0.15.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
