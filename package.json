{
  "name": "filepond-plugin-zipper",
  "version": "3.0.0",
  "description": "Zip Filepond Directory Uploads",
  "type": "module",
  "main": "dist/zipper.cjs",
  "module": "dist/zipper.js",
  "unpkg": "dist/zipper.min.js",
  "types": "dist/zipper.d.ts",
  "exports": {
    ".": {
      "types": "./dist/zipper.d.ts",
      "import": "./dist/zipper.js",
      "require": "./dist/zipper.cjs",
      "default": "./dist/zipper.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tzsk/filepond-plugin-zipper.git"
  },
  "keywords": [
    "filepond",
    "zip directory",
    "upload zipped directory",
    "filepond zip directory"
  ],
  "author": {
    "name": "Kazi Ahmed",
    "email": "mailtokmahmed@gmail.com",
    "url": "https://github.com/tzsk"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tzsk/filepond-plugin-zipper/issues"
  },
  "homepage": "https://github.com/tzsk/filepond-plugin-zipper#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^4.0.18",
    "filepond": "^4.32.12",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
